def build_project_batch_markdown(batch, project_config):
    pm_guids = set()
    raw_pms = project_config.get("pm_guid")
    if raw_pms:
        if isinstance(raw_pms, list):
            pm_guids.update(raw_pms)
        elif isinstance(raw_pms, str):
            pm_guids.add(raw_pms)

    parts = []

    for proj in batch:
        proj_name = proj.get("project_name", "未分类")

        parts.append(f"# 📌 {proj_name}")
        parts.append("")

        for member in proj.get("members", []):
            mention_obj = member.get("mention", {})
            name_md = mention_to_markdown(mention_obj)

            user_id = (mention_obj.get("attrs") or {}).get("id", "")
            is_pm = user_id in pm_guids

            pm_tag = " **项目负责人**" if is_pm else ""
            parts.append(f"## 👤 {name_md}{pm_tag}")

            progress = member.get("progress", "")
            risk = member.get("risk", "")
            help_text = member.get("help", "")
            next_focus = member.get("next_focus", "")

            if progress:
                parts.append(f"- **进展：** {progress}")
            if risk:
                parts.append(f"- **风险：** {risk}")
            if help_text:
                parts.append(f"- **协助：** {help_text}")
            if next_focus:
                parts.append(f"- **下周重点：** {next_focus}")

            if not any([progress, risk, help_text, next_focus]):
                parts.append("- （该主题暂无可结构化内容）")

            parts.append("")

        parts.append("---")
        parts.append("")

    return "\n".join(parts)

