def process_extraction_batch(batch_idx, total_batches, batch, project):
    project_name = project.get("project_name", "Unknown")
    print(f"    [Batch {batch_idx}/{total_batches}][{project_name}] 开始处理，人数: {len(batch)}")
    extracted = extract_structured_topics_from_batch(batch, project)
    print(f"    [Batch {batch_idx}/{total_batches}][{project_name}] ✅ 处理完成")
    return batch_idx, extracted


def extract_structured_topics_in_parallel(users, project, max_users_per_batch=5, max_parallel_batches=50):
    project_name = project.get("project_name", "Unknown")
    batches = split_users_into_batches(users, max_users_per_batch=max_users_per_batch)

    if not batches:
        return []

    total_batches = len(batches)
    actual_parallel = min(max_parallel_batches, total_batches)

    print(f"[Step 2A][{project_name}] 开始分批结构化抽取，共 {len(users)} 人")
    print(f"    -> 分为 {total_batches} 批，每批最多 {max_users_per_batch} 人，并行数: {actual_parallel}")

    indexed_results = {}

    with ThreadPoolExecutor(max_workers=actual_parallel) as executor:
        future_to_idx = {
            executor.submit(process_extraction_batch, idx, total_batches, batch, project): idx
            for idx, batch in enumerate(batches, 1)
        }

        for future in as_completed(future_to_idx):
            batch_idx = future_to_idx[future]
            try:
                finished_idx, extracted = future.result()
                indexed_results[finished_idx] = extracted
            except Exception as e:
                print(f"    [Batch {batch_idx}/{total_batches}] ❌ 处理失败: {e}")
                raise

    return [indexed_results[i] for i in range(1, total_batches + 1)]

def split_users_into_batches(users, max_users_per_batch=5):
    batches = []
    for i in range(0, len(users), max_users_per_batch):
        batches.append(users[i:i + max_users_per_batch])
    return batches


