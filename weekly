_PROJECT_NAME_SUFFIXES = ["模块", "系统", "项目", "开发", "建设", "优化", "改造", "升级"]

def _normalize_project_name(name):
    name = (name or "").strip()
    for suffix in _PROJECT_NAME_SUFFIXES:
        if name.endswith(suffix) and len(name) > len(suffix):
            name = name[:-len(suffix)].strip()
    return name


def reorganize_by_project(merged_extracted_json):
    users = merged_extracted_json.get("users", [])

    project_map = {}

    for user in users:
        mention_obj = user.get("mention", {})
        topics = user.get("topics", [])

        for topic in topics:
            topic_name = (topic.get("name") or "未分类").strip()
            normalized = _normalize_project_name(topic_name)

            if normalized not in project_map:
                project_map[normalized] = {
                    "project_name": topic_name,
                    "name_source": topic.get("name_source", "inferred"),
                    "members": []
                }
            else:
                if topic.get("name_source") == "explicit":
                    project_map[normalized]["project_name"] = topic_name
                    project_map[normalized]["name_source"] = "explicit"

            project_map[normalized]["members"].append({
                "mention": mention_obj,
                "progress": (topic.get("progress") or "").strip(),
                "risk": (topic.get("risk") or "").strip(),
                "help": (topic.get("help") or "").strip(),
                "next_focus": (topic.get("next_focus") or "").strip(),
            })

    sorted_projects = sorted(
        project_map.values(),
        key=lambda p: p["project_name"]
    )

    print(f"    [reorganize_by_project] 归一化前项目数: {len(project_map)}, 归一化后: {len(sorted_projects)}")

    return {"projects": sorted_projects}

