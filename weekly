def _classify_section(line):
    stripped = line.strip()
    if not stripped.startswith("#"):
        return None

    text = re.sub(r'[^\w\u4e00-\u9fff]', '', stripped).lower()
    if "核心进展" in text or "本周进展" in text:
        return "progress"
    if "困难" in text or "风险" in text or "所需支持" in text:
        return "issues"
    if "nextkeyfocus" in text or "nextfocus" in text or "下一步" in text or "keyfocus" in text:
        return "help"
    if "关键进展" in text:
        return "key_summary"
    return None


def _parse_sections_from_batch_output(batch_output):
    sections = {"progress": [], "issues": [], "help": []}

    current_section = None
    for line in batch_output.split("\n"):
        classified = _classify_section(line)
        if classified:
            current_section = classified if classified in sections else None
            continue

        if current_section:
            sections[current_section].append(line)

    return sections


def aggregate_batch_summaries(batch_summaries):
    all_progress = []
    all_issues = []
    all_help = []

    for batch_output in batch_summaries:
        sections = _parse_sections_from_batch_output(batch_output)

        progress_text = "\n".join(sections["progress"]).strip()
        if progress_text:
            all_progress.append(progress_text)

        issues_text = "\n".join(sections["issues"]).strip()
        if issues_text:
            all_issues.append(issues_text)

        help_text = "\n".join(sections["help"]).strip()
        if help_text:
            all_help.append(help_text)

    return {
        "progress": "\n\n".join(all_progress),
        "issues": "\n\n".join(all_issues),
        "help": "\n\n".join(all_help),
    }


