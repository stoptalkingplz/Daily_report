def generate_project_summaries_in_parallel(batch_markdowns, project, max_parallel=50):
    project_name = project.get("project_name", "Unknown")
    total_batches = len(batch_markdowns)

    if total_batches == 0:
        return []

    actual_parallel = min(max_parallel, total_batches)

    print(f"[Step 3][{project_name}] 开始按项目分批生成周报，共 {total_batches} 批，并行数: {actual_parallel}")

    indexed_results = {}

    with ThreadPoolExecutor(max_workers=actual_parallel) as executor:
        future_to_idx = {
            executor.submit(process_summary_batch, idx, total_batches, batch_md, project): idx
            for idx, batch_md in enumerate(batch_markdowns, 1)
        }

        for future in as_completed(future_to_idx):
            batch_idx = future_to_idx[future]
            try:
                finished_idx, result = future.result()
                indexed_results[finished_idx] = result
            except Exception as e:
                print(f"    [Summary Batch {batch_idx}/{total_batches}] ❌ 处理失败: {e}")
                raise

    return [indexed_results[i] for i in range(1, total_batches + 1)]

